{
  "name": "mob",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx src/server/index.ts\" \"vite\"",
    "build": "vite build && tsc -p tsconfig.node.json",
    "start": "node dist/server/index.js",
    "install-hooks": "tsx scripts/install-hooks.ts",
    "uninstall-hooks": "tsx scripts/uninstall-hooks.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,svelte}'",
    "format:check": "prettier --check 'src/**/*.{ts,svelte}'",
    "setup": "node scripts/postinstall.cjs",
    "predev": "node scripts/postinstall.cjs",
    "prebuild": "node scripts/postinstall.cjs"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.0.0",
    "chokidar": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "prettier": "^3.8.1",
    "svelte": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.2",
    "vite": "^5.0.0",
    "vitest": "^4.1.2",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
